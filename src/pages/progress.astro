---
/** Progress page — the load/save surface plus the dashboard and profile. */
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProgressApp from '../components/profile/ProgressApp';
import { GRAMMAR_PARTS, lessonId, lessonNumber } from '../lib/grammarParts';
import { withBase } from '../lib/paths';
import groups from '../content/vocabulary/groups.json';
import words from '../content/vocabulary/words.json';

const metas = await getCollection('grammarMeta');
const titleOf = new Map(metas.map((m) => [m.id, m.data.title]));

const groupCards = groups.map((g) => ({
  slug: g.slug,
  title: g.title,
  count: g.count,
  url: withBase(`/vocabulary/${g.slug}/`),
  wordIds: words.filter((w) => w.group === g.slug).map((w) => w.id),
}));

const parts = GRAMMAR_PARTS.map((part) => ({
  numeral: part.numeral,
  title: part.title,
  lessons: Array.from({ length: part.to - part.from + 1 }, (_, i) => {
    const id = lessonId(part.from + i);
    return { id, number: lessonNumber(id), title: titleOf.get(id) ?? id, url: withBase(`/grammar/${id}/`) };
  }),
}));
---

<BaseLayout section="progress" title="Progress — LaLista" description="Load or save your progress file, and see your whole course at a glance.">
  <main class="w-full flex-1 px-4 py-10 sm:px-8">
    <ProgressApp client:only="react" groups={groupCards} parts={parts} />
  </main>
</BaseLayout>

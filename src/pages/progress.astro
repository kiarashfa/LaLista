---
/** Progress / load-save page — full implementation arrives in Round 5 (SPEC §5, §9). */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout section="progress" title="Progress — LaLista">
  <main class="mx-auto w-full max-w-[640px] flex-1 px-6 py-16 text-center">
    <h1 class="display-editorial m-0 text-4xl font-medium text-ink">Your progress, your file</h1>
    <p class="mx-auto mt-4 max-w-[480px] leading-relaxed text-ink-soft">
      LaLista has no accounts. Your progress lives in a small file you keep — load it when you arrive, save it when you're
      done. The load/save page, dashboard and profile arrive in Round 5.
    </p>
  </main>
</BaseLayout>

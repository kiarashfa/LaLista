---
/** Review — keeps Mastered words bright; never touches stage (SPEC §8). */
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReviewApp from '../../components/trainer/ReviewApp';
import { withBase } from '../../lib/paths';
---

<BaseLayout section="vocabulary" title="Review — LaLista Vocabulary" description="Low-stakes reinforcement of your Mastered Spanish words.">
  <main class="mx-auto w-full max-w-[640px] flex-1 px-4 py-10 sm:px-6">
    <h1 class="display-friendly m-0 mb-2 text-center text-3xl font-medium text-ink">Review</h1>
    <p class="m-0 mb-8 text-center text-sm text-ink-soft">Six choices, no clock, no pressure — just keeping Mastered words bright.</p>
    <ReviewApp client:only="react" vocabularyUrl={withBase('/vocabulary/')} />
  </main>
</BaseLayout>

---
/** Test — timed, 5 lives, high scores; never touches stage (SPEC §8). */
import BaseLayout from '../../layouts/BaseLayout.astro';
import TestApp from '../../components/trainer/TestApp';
import { withBase } from '../../lib/paths';
---

<BaseLayout section="vocabulary" title="Test — LaLista Vocabulary" description="Race the clock across your Mastered Spanish words.">
  <main class="mx-auto w-full max-w-[640px] flex-1 px-4 py-10 sm:px-6">
    <h1 class="display-friendly m-0 mb-2 text-center text-3xl font-medium text-ink">Test</h1>
    <p class="m-0 mb-8 text-center text-sm text-ink-soft">Three choices, a real clock, five lives. High score is the only stake.</p>
    <TestApp client:only="react" vocabularyUrl={withBase('/vocabulary/')} />
  </main>
</BaseLayout>

---
/** The workbook page — separate from the read page by design (SPEC §6). */
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import WorkbookApp from '../../../components/exercises/WorkbookApp';
import { lessonId as toLessonId, lessonNumber } from '../../../lib/grammarParts';
import { withBase } from '../../../lib/paths';
import type { Exercise } from '../../../types/exercises';

export async function getStaticPaths() {
  const metas = await getCollection('grammarMeta');
  return metas.map((meta) => ({ params: { lesson: meta.id }, props: { meta } }));
}

const { meta } = Astro.props;
const id = meta.id;
const number = lessonNumber(id);

const entry = await getEntry('grammarExercises', id);
const exercises = (entry?.data.exercises ?? []) as unknown as Exercise[];

const allMetas = await getCollection('grammarMeta');
const nextId = number < 57 ? toLessonId(number + 1) : null;
const nextTitle = nextId ? (allMetas.find((m) => m.id === nextId)?.data.title ?? null) : null;
---

<BaseLayout requireProfile section="grammar" title={`Workbook: ${meta.data.title} — LaLista`}>
  <main class="mx-auto w-full max-w-[720px] flex-1 px-4 py-10 sm:px-8">
    <a href={withBase(`/grammar/${id}/`)} class="text-sm font-semibold text-grammar no-underline">← Chapter {number}</a>
    <p class="mt-5 mb-1 text-sm font-bold tracking-wider text-grammar uppercase">Workbook · Chapter {number}</p>
    <h1 class="display-editorial m-0 mb-8 text-3xl font-medium text-ink sm:text-4xl">{meta.data.title}</h1>

    <WorkbookApp
      client:only="react"
      lessonId={id}
      lessonNumber={number}
      exercises={exercises}
      lessonUrl={withBase(`/grammar/${id}/`)}
      nextUrl={nextId ? withBase(`/grammar/${nextId}/`) : null}
      nextTitle={nextTitle}
    />
  </main>
</BaseLayout>

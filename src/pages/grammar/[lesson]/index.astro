---
/**
 * The lesson READ page — prose only; exercises live on the separate workbook
 * page reached via the explicit CTA (SPEC §6: two pages, not one scroll).
 */
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ReadGateCta from '../../../components/exercises/ReadGateCta';
import BootTable from '../../../components/mdx/BootTable.astro';
import ExampleSentence from '../../../components/mdx/ExampleSentence.astro';
import GrammarNote from '../../../components/mdx/GrammarNote.astro';
import LessonLink from '../../../components/mdx/LessonLink.astro';
import LevelBadge from '../../../components/mdx/LevelBadge.astro';
import SentenceStructure from '../../../components/mdx/SentenceStructure.astro';
import { lessonId, lessonNumber, partOf } from '../../../lib/grammarParts';
import { withBase } from '../../../lib/paths';

export async function getStaticPaths() {
  const metas = await getCollection('grammarMeta');
  return metas.map((meta) => ({ params: { lesson: meta.id }, props: { meta } }));
}

const { meta } = Astro.props;
const id = meta.id;
const number = lessonNumber(id);

const lesson = await getEntry('grammarLessons', id);
if (!lesson) throw new Error(`Missing lesson.mdx for ${id}`);
const { Content } = await render(lesson);

const exercises = await getEntry('grammarExercises', id);
const exerciseCount = exercises?.data.exercises.length ?? 0;
const exerciseTypes = [...new Set(exercises?.data.exercises.map((e) => e.type) ?? [])];

const allMetas = await getCollection('grammarMeta');
const titleOf = (lid: string) => allMetas.find((m) => m.id === lid)?.data.title ?? lid;

const part = partOf(id);
const partIds = Array.from({ length: part.to - part.from + 1 }, (_, i) => lessonId(part.from + i));
const prevId = number > 1 ? lessonId(number - 1) : null;
const nextId = number < 57 ? lessonId(number + 1) : null;

// H2 section headings for every chapter in this Part — powers the expandable
// TOC (owner refinement #4). The current chapter starts expanded.
const partToc = await Promise.all(
  partIds.map(async (pid) => {
    const entry = await getEntry('grammarLessons', pid);
    const rendered = entry ? await render(entry) : null;
    return {
      pid,
      sections: (rendered?.headings ?? []).filter((h) => h.depth === 2),
    };
  }),
);

const components = {
  BootTable,
  ExampleSentence,
  GrammarNote,
  LevelBadge,
  SentenceStructure,
  a: LessonLink,
};
---

<BaseLayout requireProfile section="grammar" title={`${meta.data.title} — LaLista Grammar`} description={meta.data.summary}>
  <div id="lesson-grid" class="collapsible-grid relative mx-auto grid w-full max-w-[1100px] flex-1 grid-cols-1 lg:grid-cols-[260px_minmax(0,1fr)]">
    <aside class="collapsible-aside hidden border-r border-border px-6 py-10 lg:block">
      <nav class="sticky top-6 max-h-[calc(100vh-3rem)] overflow-y-auto pr-1">
        <div class="mb-3 flex items-center justify-between gap-2">
          <p class="m-0 truncate text-xs font-bold tracking-widest text-grammar uppercase">Part {part.numeral} · {part.title}</p>
          <button
            type="button"
            id="toc-close"
            aria-label="Hide chapter list"
            title="Hide chapter list"
            class="flex h-6 w-6 shrink-0 cursor-pointer items-center justify-center rounded-sm text-ink-faint hover:bg-surface-sunken hover:text-ink"
          >
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m15 6-6 6 6 6"></path>
            </svg>
          </button>
        </div>
        {
          partToc.map(({ pid, sections }) => (
            <details open={pid === id} class="toc-chapter group">
              <summary class="flex cursor-pointer list-none items-start gap-1 select-none [&::-webkit-details-marker]:hidden">
                <svg
                  class="toc-chevron mt-2.5 h-3 w-3 shrink-0 text-ink-faint transition-transform duration-150 group-open:rotate-90"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="m9 6 6 6-6 6"></path>
                </svg>
                <a
                  href={withBase(`/grammar/${pid}/`)}
                  class:list={[
                    'block flex-1 border-l-2 py-2 pl-2.5 text-[0.92rem] no-underline',
                    pid === id ? 'border-grammar font-semibold text-grammar' : 'border-transparent text-ink-faint hover:text-ink',
                  ]}
                >
                  {lessonNumber(pid)} · {titleOf(pid)}
                </a>
              </summary>
              {sections.length > 0 && (
                <ul class="m-0 mb-1 list-none p-0 pl-7">
                  {sections.map((s) => (
                    <li>
                      <a
                        href={withBase(`/grammar/${pid}/#${s.slug}`)}
                        class="block border-l border-border py-1 pl-3 text-[0.8rem] leading-snug text-ink-faint no-underline hover:border-grammar hover:text-grammar"
                      >
                        {s.text}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </details>
          ))
        }
      </nav>
    </aside>

    <button
      type="button"
      id="toc-reopen"
      aria-label="Show chapter list"
      title="Show chapter list"
      class="toc-reopen-handle absolute top-16 left-0 z-10 hidden h-14 w-6 cursor-pointer items-center justify-center rounded-r-md border border-l-0 border-border bg-surface-raised text-ink-faint shadow-sm hover:text-grammar lg:flex"
    >
      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m9 6 6 6-6 6"></path>
      </svg>
    </button>
    <script is:inline>
      // Apply the stored collapse state before first paint (no flash/animation).
      if (localStorage.getItem('lalista:lessonToc') === 'closed') {
        document.getElementById('lesson-grid')?.classList.add('closed');
      }
    </script>

    <article class="w-full max-w-[720px] px-6 py-12 sm:px-10">
      <header class="relative">
        {/* Ghosted ¡ — anchored to the article column (not the grid), so it can't clip into the sidebar (§7 punch list) */}
        <span class="font-display pointer-events-none absolute -top-6 -left-3 z-0 text-[10rem] leading-none font-light text-grammar opacity-[0.07] select-none" aria-hidden="true">¡</span>
        <p class="relative z-10 m-0 mb-3 text-sm font-bold tracking-wider text-grammar uppercase">Chapter {number} · {meta.data.level}</p>
        <h1 class="display-editorial relative z-10 m-0 mb-6 text-4xl leading-tight font-medium text-ink sm:text-[2.6rem]">{meta.data.title}</h1>
      </header>

      {
        meta.data.prerequisites.length > 0 && (
          <p class="mb-8 rounded-md bg-surface-sunken px-4 py-3 text-sm text-ink-soft">
            Might help first:{' '}
            {meta.data.prerequisites.map((pid, i) => (
              <>
                {i > 0 && ', '}
                <a href={withBase(`/grammar/${pid}/`)} class="font-semibold text-grammar">
                  Ch. {lessonNumber(pid)} — {titleOf(pid)}
                </a>
              </>
            ))}
            <span class="text-ink-faint"> (a suggestion, never a requirement)</span>
          </p>
        )
      }

      <div class="lesson-prose">
        <Content components={components} />
      </div>

      <ReadGateCta
        client:visible
        lessonId={id}
        workbookUrl={withBase(`/grammar/${id}/workbook/`)}
        exerciseCount={exerciseCount}
        typesPreview={`${exerciseTypes.slice(0, 3).join(', ')}${exerciseTypes.length > 3 ? '…' : ''}`}
      />

      <nav class="mt-10 flex justify-between gap-4 border-t border-border pt-6 text-sm">
        {
          prevId ? (
            <a href={withBase(`/grammar/${prevId}/`)} class="max-w-[45%] text-ink-faint no-underline hover:text-grammar">
              ← Ch. {number - 1} · {titleOf(prevId)}
            </a>
          ) : (
            <span />
          )
        }
        {
          nextId ? (
            <a href={withBase(`/grammar/${nextId}/`)} class="max-w-[45%] text-right text-ink-faint no-underline hover:text-grammar">
              Ch. {number + 1} · {titleOf(nextId)} →
            </a>
          ) : (
            <span />
          )
        }
      </nav>
    </article>
  </div>

  <script>
    const grid = document.getElementById('lesson-grid');
    const KEY = 'lalista:lessonToc';
    document.getElementById('toc-close')?.addEventListener('click', () => {
      grid?.classList.add('closed');
      localStorage.setItem(KEY, 'closed');
    });
    document.getElementById('toc-reopen')?.addEventListener('click', () => {
      grid?.classList.remove('closed');
      localStorage.setItem(KEY, 'open');
    });
  </script>
</BaseLayout>

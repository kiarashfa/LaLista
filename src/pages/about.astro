---
/**
 * About page — what LaLista is, how each section works, who builds it,
 * and how to support it. All copy lives right here in plain HTML.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/paths';
import groups from '../content/vocabulary/groups.json';
import words from '../content/vocabulary/words.json';
---

<BaseLayout
  section="about"
  title="About — LaLista"
  description="What LaLista is and how to use it: a free Spanish (Castellano) vocabulary trainer and complete grammar reference — no ads, no accounts, your progress in a file you keep."
>
  <main class="mx-auto w-full max-w-[720px] flex-1 px-6 py-12 sm:px-8">
    <header class="relative mb-12">
      <span class="font-display pointer-events-none absolute -top-8 -left-3 z-0 text-[9rem] leading-none font-light text-vocab opacity-[0.06] select-none" aria-hidden="true">¿</span>
      <h1 class="display-editorial relative z-10 m-0 text-4xl font-medium text-ink sm:text-5xl">About LaLista</h1>
      <p class="relative z-10 mt-4 text-lg leading-relaxed text-ink-soft">
        LaLista is a free place to learn Spanish — Castellano, specifically. {words.length} words with real
        pronunciation and a grammar reference that covers every topic completely, side by side on one site. No ads, no
        accounts, no cookie banners. Just the list.
      </p>
    </header>

    <section class="mb-12">
      <p class="m-0 text-xs font-bold tracking-widest text-vocab uppercase">Vocabulary</p>
      <h2 class="display-friendly m-0 mt-2 text-2xl font-semibold text-ink">Words, three ways</h2>
      <p class="mt-3 leading-relaxed text-ink-soft">
        The <a href={withBase('/vocabulary/')} class="font-semibold text-vocab underline">vocabulary trainer</a> holds {words.length} words
        in {groups.length} topic groups — colors, food, travel and so on — each with audio, phonetics and an example
        sentence. Three modes share them:
      </p>
      <ul class="mt-3 flex list-none flex-col gap-3 p-0">
        <li class="rounded-md border border-border bg-surface-raised px-4 py-3 leading-relaxed text-ink-soft shadow-sm">
          <b class="text-ink">Group Study</b> — where learning happens. Pick a group; new words arrive in small
          batches and get quizzed until they climb the seven stages from <i>New</i> to <i>Mastered</i>. Skip what you
          don't know yet, flag difficult words, mark words you already know — and pin a note to any word to make it
          stick.
        </li>
        <li class="rounded-md border border-border bg-surface-raised px-4 py-3 leading-relaxed text-ink-soft shadow-sm">
          <b class="text-ink">Review</b> — relaxed reinforcement: six choices, no clock. Mix any directions
          (English→Spanish, Spanish→English, listening) in one run, over everything you've mastered or a single group.
          Review never changes a word's learning stage — it just keeps it bright.
        </li>
        <li class="rounded-md border border-border bg-surface-raised px-4 py-3 leading-relaxed text-ink-soft shadow-sm">
          <b class="text-ink">Test</b> — the opposite: three choices, a real clock, five lives, and a high score to
          beat. Pure recall under pressure, with your learning progress safely out of reach.
        </li>
      </ul>
    </section>

    <section class="mb-12">
      <p class="m-0 text-xs font-bold tracking-widest text-grammar uppercase">Grammar</p>
      <h2 class="display-editorial m-0 mt-2 text-2xl font-semibold text-ink">One topic, told completely</h2>
      <p class="mt-3 leading-relaxed text-ink-soft">
        The <a href={withBase('/grammar/')} class="font-semibold text-grammar underline">grammar reference</a> has 57
        chapters in 13 parts. Instead of slicing a topic into pieces across difficulty levels, each chapter tells one
        story end to end — <i>ser</i> vs <i>estar</i>, the subjunctive, <i>por</i> vs <i>para</i> — from the first idea
        to the finest exceptions, so there's always exactly one place to look something up.
      </p>
      <p class="mt-3 leading-relaxed text-ink-soft">
        Read a chapter, mark it read, then open its <b class="text-ink">workbook</b>: interactive exercises — multiple
        choice, fill-in-the-blank, error correction, conjugation grids, sentence reordering and more. Retake them as
        often as you like; only your best score counts, so a bad day never sets you back.
      </p>
    </section>

    <section class="mb-12">
      <p class="m-0 text-xs font-bold tracking-widest text-success uppercase">Progress</p>
      <h2 class="display-friendly m-0 mt-2 text-2xl font-semibold text-ink">No accounts — a file you keep</h2>
      <p class="mt-3 leading-relaxed text-ink-soft">
        There is nothing to sign into. Your progress lives in a small file on your own computer: load it on
        the <a href={withBase('/progress/')} class="font-semibold text-ink underline">Progress page</a> when you
        arrive, hit save when you're done. The same page is your dashboard — every group and chapter at a glance —
        plus your streak, test bests, and a notepad for your own notes, word mnemonics included.
      </p>
    </section>

    <section class="mb-12 rounded-lg border border-border bg-surface-raised p-6 shadow-md sm:p-8">
      <div class="flex flex-col items-start gap-6 sm:flex-row">
        <img
          src="https://raw.githubusercontent.com/kiarashfa/website/main/assets/imgs/MyPic.png"
          alt="Kiarash Farajzadehahary"
          width="112"
          height="112"
          loading="lazy"
          class="h-28 w-28 shrink-0 rounded-pill border border-border object-cover"
        />
        <div class="min-w-0">
          <h2 class="display-friendly m-0 text-2xl font-semibold text-ink">Kiarash Farajzadehahary</h2>
          <p class="m-0 mt-1 text-sm font-semibold text-ink-faint">Scientist · developer · designer · Spanish learner</p>
          <p class="mt-4 leading-relaxed text-ink-soft">
            I built LaLista because the site I wanted to learn from didn't exist. Everything I tried treated vocabulary
            and grammar as separate worlds — great flashcards with barely any grammar, or solid grammar chopped into
            fragments — and the rest sat behind subscriptions, ads, accounts and cookie walls. I wanted one quiet,
            complete place where the two are learned together. So I built it.
          </p>
          <p class="mt-3 leading-relaxed text-ink-soft">
            LaLista is the tool I study with myself; if it helps you too, it's doing its job.
          </p>
          <p class="mt-4 flex flex-wrap gap-2 text-sm">
            <a
              href="https://kiarashfa.github.io/website/"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1.5 rounded-pill border-2 border-border px-3.5 py-1.5 font-semibold text-ink no-underline hover:border-ink-faint"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M2 12h20"></path>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
              </svg>
              Personal site
            </a>
            <a
              href="https://github.com/kiarashfa"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1.5 rounded-pill border-2 border-border px-3.5 py-1.5 font-semibold text-ink no-underline hover:border-ink-faint"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"></path>
              </svg>
              GitHub
            </a>
            <a
              href="mailto:Kiarashfa@gmail.com"
              class="inline-flex items-center gap-1.5 rounded-pill border-2 border-border px-3.5 py-1.5 font-semibold text-ink no-underline hover:border-ink-faint"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                <path d="m22 6-10 7L2 6"></path>
              </svg>
              Kiarashfa@gmail.com
            </a>
          </p>
        </div>
      </div>
    </section>

    <section class="mb-4 text-center">
      <p class="m-0 text-xs font-bold tracking-widest text-gold uppercase">Support</p>
      <h2 class="display-friendly m-0 mt-2 text-2xl font-semibold text-ink">Keep the coffee warm</h2>
      <p class="mx-auto mt-3 max-w-[480px] leading-relaxed text-ink-soft">
        LaLista is free and stays free — no ads, ever. If it has earned a spot in your Spanish routine and you feel
        like giving something back, a coffee genuinely helps.
      </p>
      <p class="mt-5 flex flex-wrap justify-center gap-3">
        <a
          href="https://www.buymeacoffee.com/kiarashfa"
          target="_blank"
          rel="noopener"
          class="inline-flex h-11 w-56 items-center justify-center gap-2 rounded-pill bg-gold text-sm font-bold text-white no-underline hover:opacity-90"
        >
          {/* Buy Me a Coffee mark (simple-icons, CC0) */}
          <svg class="h-4.5 w-4.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.216 6.415l-.132-.666c-.119-.598-.388-1.163-1.001-1.379-.197-.069-.42-.098-.57-.241-.152-.143-.196-.366-.231-.572-.065-.378-.125-.756-.192-1.133-.057-.325-.102-.69-.25-.987-.195-.4-.597-.634-.996-.788a5.723 5.723 0 00-.626-.194c-1-.263-2.05-.36-3.077-.416a25.834 25.834 0 00-3.7.062c-.915.083-1.88.184-2.75.5-.318.116-.646.256-.888.501-.297.302-.393.77-.177 1.146.154.267.415.456.692.58.36.162.737.284 1.123.366 1.075.238 2.189.331 3.287.37 1.218.05 2.437.01 3.65-.118.299-.033.598-.073.896-.119.352-.054.578-.513.474-.834-.124-.383-.457-.531-.834-.473-.466.074-.96.108-1.382.146-1.177.08-2.358.082-3.536.006a22.228 22.228 0 01-1.157-.107c-.086-.01-.18-.025-.258-.036-.243-.036-.484-.08-.724-.13-.111-.027-.111-.185 0-.212h.005c.277-.06.557-.108.838-.147h.002c.131-.009.263-.032.394-.048a25.076 25.076 0 013.426-.12c.674.019 1.347.067 2.017.144l.228.031c.267.04.533.088.798.145.392.085.895.113 1.07.542.055.137.08.288.111.431l.319 1.484a.237.237 0 01-.199.284h-.003c-.037.006-.075.01-.112.015a36.704 36.704 0 01-4.743.295 37.059 37.059 0 01-4.699-.304c-.14-.017-.293-.042-.417-.06-.326-.048-.649-.108-.973-.161-.393-.065-.768-.032-1.123.161-.29.16-.527.404-.675.701-.154.316-.199.66-.267 1-.069.34-.176.707-.135 1.056.087.753.613 1.365 1.37 1.502a39.69 39.69 0 0011.343.376.483.483 0 01.535.53l-.071.697-1.018 9.907c-.041.41-.047.832-.125 1.237-.122.637-.553 1.028-1.182 1.171-.577.131-1.165.2-1.756.205-.656.004-1.31-.025-1.966-.022-.699.004-1.556-.06-2.095-.58-.475-.458-.54-1.174-.605-1.793l-.731-7.013-.322-3.094c-.037-.351-.286-.695-.678-.678-.336.015-.718.3-.678.679l.228 2.185.949 9.112c.147 1.344 1.174 2.068 2.446 2.272.742.12 1.503.144 2.257.156.966.016 1.942.053 2.892-.122 1.408-.258 2.465-1.198 2.616-2.657.34-3.332.683-6.663 1.024-9.995l.215-2.087a.484.484 0 01.39-.426c.402-.078.787-.212 1.074-.518.455-.488.546-1.124.385-1.766zm-1.478.772c-.145.137-.363.201-.578.233-2.416.359-4.866.54-7.308.46-1.748-.06-3.477-.254-5.207-.498-.17-.024-.353-.055-.47-.18-.22-.2
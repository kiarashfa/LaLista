    {
      "id": "ex-5",
      "type": "multiple-choice",
      "prompt": "¿Qué hora es? No sé, ___ las tres. (a guess about right now, not a future statement)",
      "options": ["será", "es", "fue", "sería"],
      "correctAnswer": "será"
    },
    {

      "blankForms": ["tú", "él/ella/usted", "vosotros", "ellos/ellas/ustedes"],
      "correctAnswers": { "tú": "pondrás", "él/ella/usted": "pondrá", "vosotros": "pondréis", "ellos/ellas/ustedes": "pondrán" }
    },
    {
      "id": "ex-4",
      "type": "error-correction",
      "prompt": "Find and fix the mistake — an irregular stem regularized by mistake:",
